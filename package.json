{
  "name": "jira-worklog-cse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,WEB -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "nodemon --config nodemon.json server/index.js",
    "dev:web": "vite",
    "build": "vite build && vite build --ssr src/entry-server.jsx --outDir dist/server",
    "start": "node server/index.js"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.10",
    "vite": "^8.0.0"
  }
}
